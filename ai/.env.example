# Application
APP_NAME=ATORIA AI Service
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=info

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=atoria_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/atoria_ai

# OpenAI (SSAFY GMS proxy)
OPENAI_API_KEY=your-gms-key-here
OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REQUEST_TIMEOUT=60

# LLM Parameters
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9

# RAG Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
NUM_RETRIEVAL_CHUNKS=5
SIMILARITY_THRESHOLD=0.6

# API Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
API_V1_PREFIX=/api/v1

# Service Configuration
ENABLE_AI_REQUEST_LOGGING=true
RETRY_ATTEMPTS=3
RETRY_DELAY=1
